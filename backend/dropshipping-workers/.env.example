# Cloudflare Workers Environment Variables
# Copy this to .env and fill in with real values

# GlowRoad
GLOWROAD_API_KEY=your_glowroad_api_key
GLOWROAD_API_SECRET=your_glowroad_api_secret
GLOWROAD_MERCHANT_ID=your_glowroad_merchant_id

# Roposo Clout
ROPOSO_CLOUT_API_KEY=your_roposo_clout_api_key
ROPOSO_CLOUT_SELLER_ID=your_roposo_clout_seller_id

# CJ Dropshipping
CJ_DROPSHIPPING_API_KEY=your_cj_dropshipping_api_key
CJ_DROPSHIPPING_ACCESS_TOKEN=your_cj_dropshipping_access_token

# Security
JWT_SECRET=your_jwt_secret_key_here
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Database
D1_DATABASE_ID=your_d1_database_id

# KV Storage
KV_NAMESPACE_ID=your_kv_namespace_id
