# Frontend Environment Variables for Dropshipping Integration

# ========================================
# Cloudflare Workers Backend Configuration
# ========================================

# Backend API URL (Cloudflare Workers or your deployed backend)
VITE_BACKEND_URL=https://api.yourdomain.com/api

# API Token for authentication (optional, for admin operations)
VITE_API_TOKEN=your_frontend_api_token

# ========================================
# Margin Configuration
# ========================================

# Default profit margin percentage
VITE_DEFAULT_MARGIN_PERCENTAGE=30

# Enable bulk pricing tiers
VITE_ENABLE_BULK_PRICING=true

# ========================================
# Supplier Status (for UI visibility)
# ========================================

VITE_GLOWROAD_ENABLED=true
VITE_ROPOSO_ENABLED=true
VITE_CJ_ENABLED=true

# ========================================
# Product Sync Configuration
# ========================================

# Auto-refresh products every X milliseconds
VITE_PRODUCT_SYNC_INTERVAL=3600000

# Cache product list locally for X milliseconds
VITE_PRODUCT_CACHE_TTL=1800000

# ========================================
# Analytics & Tracking
# ========================================

# Track dropshipping order submissions
VITE_ENABLE_ORDER_TRACKING=true

# ========================================
# Development Only
# ========================================

# Set to true to mock API responses locally
VITE_MOCK_API=false

# Local backend URL for development
VITE_DEV_BACKEND_URL=http://localhost:8787/api
